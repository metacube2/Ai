                        {
                            <MudTh>@year</MudTh>
                        }
                        <MudTh>@T("Gesamtergebnis", "Grand total")</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Month</MudTd>
                        <MudTd>@context.Day</MudTd>
                        @foreach (var year in BuildFinancePivotDailyYearColumns())
                        {
                            <MudTd>@FormatNullableValue(GetFinancePivotValue(context, year), "CHF")</MudTd>
                        }
                        <MudTd>@FormatValue(CalculateFinancePivotRowTotal(context, BuildFinancePivotDailyYearColumns()), "CHF")</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2">@T("Keine Tagesdaten fuer den gewaehlten Monat.", "No daily data for the selected month.")</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
