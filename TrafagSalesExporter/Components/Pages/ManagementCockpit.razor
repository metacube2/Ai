                <MudTable Items="BuildFinancePivotMonthlyRows()" Dense Hover Striped>
                    <HeaderContent>
                        <MudTh>YYYY</MudTh>
                        <MudTh>MM</MudTh>
                        @foreach (var tsc in BuildFinancePivotTscColumns())
                        {
                            <MudTh>@tsc</MudTh>
                        }
                        <MudTh>@T("Gesamtergebnis", "Grand total")</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@FormatFinancePivotYearCell(context)</MudTd>
                        <MudTd>@(context.Month?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)</MudTd>
                        @foreach (var tsc in BuildFinancePivotTscColumns())
                        {
                            <MudTd>@FormatNullableValue(GetFinancePivotValue(context, tsc), "CHF")</MudTd>
                        }
                        <MudTd>@FormatValue(CalculateFinancePivotRowTotal(context, BuildFinancePivotTscColumns()), "CHF")</MudTd>
                    </RowTemplate>
