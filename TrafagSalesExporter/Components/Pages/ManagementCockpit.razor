                MatchesFilter(row.Year, _financeAuditYearFilter) &&
                MatchesFilter(row.InvoiceNumber, _financeAuditInvoiceFilter) &&
                MatchesFilter(row.PositionOnInvoice, _financeAuditPositionFilter) &&
                MatchesFilter(string.Join(' ', row.CustomerNumber, row.CustomerName), _financeAuditCustomerFilter) &&
                MatchesFilter(string.Join(' ', row.Material, row.ArticleName), _financeAuditMaterialFilter) &&
                MatchesFilter(row.OriginalAmount, _financeAuditOriginalAmountFilter) &&
                MatchesFilter(row.OriginalCurrency, _financeAuditOriginalCurrencyFilter) &&
                MatchesFilter(row.ChfRate, _financeAuditChfRateFilter) &&
                MatchesFilter(row.ChfAmount, _financeAuditChfAmountFilter) &&
                MatchesFilter(string.Join(' ', row.RateSource, row.RateYear), _financeAuditRateSourceFilter) &&
                MatchesFilter(string.Join(' ', row.SupplierNumber, row.SupplierName, row.SupplierCountry), _financeAuditSupplierFilter) &&
                MatchesFilter(row.SupplierType, _financeAuditSupplierTypeFilter) &&
                MatchesFilter(string.Join(' ', FormatInvariant(row.StandardCost), row.StandardCostCurrency), _financeAuditStandardCostFilter) &&
                MatchesFilter(row.CostBasisChf, _financeAuditCostBasisFilter) &&
                MatchesFilter(row.MarginChf, _financeAuditMarginFilter) &&
                MatchesFilter(row.DataSource, _financeAuditDataSourceFilter))
