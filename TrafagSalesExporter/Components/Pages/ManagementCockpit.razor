    private IReadOnlyList<IReadOnlyDictionary<string, object?>> BuildFinancePivotExportRows(
        IEnumerable<ManagementFinancePivotMatrixRow> rows,
        IReadOnlyList<string>? valueColumns = null)
    {
        var columns = valueColumns ?? _financeResult?.FinancePivot.TscColumns ?? [];
        return rows
            .Select(row =>
            {
                var dict = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase)
                {
                    ["YYYY"] = FormatFinancePivotYearCell(row),
                    ["MM"] = row.Month,
                    ["D"] = row.Day
                };

                foreach (var column in columns)
                    dict[column] = GetFinancePivotValue(row, column);

                dict[T("Gesamtergebnis", "Grand total")] = CalculateFinancePivotRowTotal(row, columns);
                return (IReadOnlyDictionary<string, object?>)dict;
            })
            .ToList();
    }

    private static bool MatchesFilter(object? value, string? filter)
    {
        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var text = value switch
        {
            null => string.Empty,
            decimal decimalValue => FormatInvariant(decimalValue),
            int intValue => intValue.ToString(CultureInfo.InvariantCulture),
            _ => value.ToString() ?? string.Empty
        };

        return text.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatInvariant(decimal value)
        => value.ToString("0.#############################", CultureInfo.InvariantCulture);

