    private async Task DownloadExcel(string fileLabel, IReadOnlyList<ExcelSheetData> sheets)
    {
        if (_financeResult is null)
        {
            Snackbar.Add(T("Bitte zuerst Finance Summary laden.", "Please load the finance summary first."), Severity.Warning);
            return;
        }

        try
        {
            var bytes = ExcelExport.CreateWorkbookBytes(sheets);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"{fileLabel}_{_selectedFinanceYear}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JsRuntime.InvokeVoidAsync("trafagDownload.saveBytes", fileName, base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(T("Excel-Export fehlgeschlagen: {0}", "Excel export failed: {0}"), ex.Message), Severity.Error);
        }
    }

    private static IReadOnlyList<IReadOnlyDictionary<string, object?>> BuildRows<T>(IEnumerable<T> items)
    {
        var properties = typeof(T)
            .GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(p => p.CanRead && p.GetIndexParameters().Length == 0)
            .ToList();

        return items
            .Select(item =>
            {
                var dict = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
                foreach (var property in properties)
                    dict[property.Name] = property.GetValue(item);
                return (IReadOnlyDictionary<string, object?>)dict;
            })
            .ToList();
    }

