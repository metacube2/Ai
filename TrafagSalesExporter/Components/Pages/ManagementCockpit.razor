    private static string FormatDateTime(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "-";

    // Normalize each source to UTC before comparing: StoredAtUtc is UTC, ExtractionDate
    // and ExportAt are local time (matches DashboardPageService.ResolveDataFreshness).
    // Returns a Kind=Utc DateTime so FormatDateTime's ToLocalTime() displays correctly.
    private static DateTime? ToUtcFreshness(DateTime? value, DateTimeKind sourceKind)
        => value.HasValue
            ? (sourceKind == DateTimeKind.Utc
                ? DateTime.SpecifyKind(value.Value, DateTimeKind.Utc)
                : DateTime.SpecifyKind(value.Value, DateTimeKind.Local).ToUniversalTime())
            : null;

    private string BuildDataStatusTooltip(ManagementFinanceDataStatusRow row)
    {
        var parts = new List<string>();
        if (row.LatestExtractionDate.HasValue)
            parts.Add($"{T("Extraktionsdatum", "Extraction date")}: {FormatDateTime(ToUtcFreshness(row.LatestExtractionDate, DateTimeKind.Local))}");
        if (row.LatestStoredAtUtc.HasValue)
            parts.Add($"{T("DB-Import", "DB import")}: {FormatDateTime(ToUtcFreshness(row.LatestStoredAtUtc, DateTimeKind.Utc))}");
        if (row.LatestExportAt.HasValue)
            parts.Add($"{T("Letzter Export", "Last export")}: {FormatDateTime(ToUtcFreshness(row.LatestExportAt, DateTimeKind.Local))}");
        if (!string.IsNullOrWhiteSpace(row.DataFreshnessDetails))
            parts.Add(row.DataFreshnessDetails);
        return parts.Count > 0 ? string.Join(" | ", parts) : T("Kein Datenstand verfügbar", "No data freshness available");
    }

    private static string FormatManualImportStatus(ManagementFinanceDataStatusRow row)
    {
        if (!string.Equals(row.SourceSystem, "MANUAL_EXCEL", StringComparison.OrdinalIgnoreCase))
            return "-";

        if (!string.IsNullOrWhiteSpace(row.ManualImportFilePath))
            return row.ManualImportLastUploadedAtUtc.HasValue
                ? $"{System.IO.Path.GetFileName(row.ManualImportFilePath)} / {FormatDateTime(row.ManualImportLastUploadedAtUtc)}"
                : System.IO.Path.GetFileName(row.ManualImportFilePath);

        return "kein Pfad";
    }

    private string BuildDataStatusText(ManagementFinanceCountryStatusRow countryRow)
    {
        if (_financeResult is null)
            return "-";

        var tscs = countryRow.Tscs
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var matchingRows = _financeResult.DataStatusRows
            .Where(row => row.Land.Equals(countryRow.CountryKey, StringComparison.OrdinalIgnoreCase) ||
                          tscs.Contains(row.Tsc))
            .OrderByDescending(row => row.DataFreshnessAt ?? DateTime.MinValue)
            .ToList();

        var latest = matchingRows.FirstOrDefault();
        if (latest is null)
            return "-";

        // Use the same freshness as the Export Dashboard (DB vs. local CSV vs. export log) so the
        // quick overview agrees with the Export Dashboard, including the "CSV neuer als DB" flag.
        var source = string.IsNullOrWhiteSpace(latest.DataFreshnessSource) ? latest.SourceSystem : latest.DataFreshnessSource;
        var text = $"{source} / {FormatDateTime(latest.DataFreshnessAt)}";
        if (latest.IsCsvNewerThanDatabase)
            text += $" / {T("CSV neuer als DB", "CSV newer than DB")}";
        return text;
    }

    private string BuildQuickFinanceNote(ManagementFinanceCountryStatusRow row)
    {
        if (!row.ReferenceValue.HasValue)
            return T("Kein Sollwert gepflegt.", "No reference value maintained.");
        if (row.TotalRows == 0)
            return T("Sollwert gepflegt, aber kein Ist im aktuellen Filter.", "Reference maintained, but no actuals in the current filter.");
        if (row.Status == "OK")
            return T("Freigabefaehig.", "Ready for approval.");
        if (row.Difference.HasValue)
            return T("Abweichung pruefen.", "Check deviation.");

        return T("Pruefen.", "Check.");
    }

