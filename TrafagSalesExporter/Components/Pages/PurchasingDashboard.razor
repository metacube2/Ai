    private int DataReadinessPercent
    {
        get
        {
            var ready = 0;
            if (_liveState.EkkoLoaded)
                ready++;
            if (_liveState.EkpoLoaded)
                ready++;
            if (_liveState.EketLoaded)
                ready++;
            return (int)Math.Round(ready / 3d * 100d);
        }
    }

    private string DataReadinessText
        => DataReadinessPercent switch
